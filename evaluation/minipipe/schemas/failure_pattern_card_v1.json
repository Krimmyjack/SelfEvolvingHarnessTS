{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "failure-pattern-card/1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "pattern_id",
    "support_count",
    "case_ids",
    "observable_signature",
    "observable_signature_hash",
    "contexts",
    "first_stage",
    "fault_code",
    "cause_code",
    "actionability",
    "common_behavior_signature",
    "sanitized_intervention_receipts",
    "matched_success_case_ids",
    "counterexample_case_ids",
    "missing_success_contrast",
    "suspect_surface_templates",
    "capability_state",
    "observable_applicability"
  ],
  "properties": {
    "schema_version": {"const": "failure-pattern-card/1"},
    "pattern_id": {"type": "string", "pattern": "^pattern-[0-9a-f]{12}$"},
    "support_count": {"type": "integer", "minimum": 2},
    "case_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "observable_signature": {"type": "object"},
    "observable_signature_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "contexts": {"type": "object"},
    "first_stage": {"type": ["string", "null"]},
    "fault_code": {"type": "string"},
    "cause_code": {"type": "string"},
    "actionability": {"type": "string"},
    "common_behavior_signature": {"type": "object"},
    "sanitized_intervention_receipts": {"type": "array", "items": {"type": "object"}},
    "matched_success_case_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "counterexample_case_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "missing_success_contrast": {"type": "boolean"},
    "suspect_surface_templates": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "capability_state": {"enum": ["missing", "misrouted", "insufficient", "risk", "unknown"]},
    "observable_applicability": {"type": ["object", "null"]}
  }
}
