{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "public-case-view/1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "case_id", "series", "task_kind", "public_features", "public_probe_panel", "public_case_view_sha"],
  "properties": {
    "schema_version": {"const": "public-case-view/1"},
    "case_id": {"type": "string", "pattern": "^m0-[0-9]{4}$"},
    "series": {"type": "object"},
    "task_kind": {"type": "string"},
    "public_features": {"type": "object"},
    "public_probe_panel": {"type": ["object", "null"]},
    "public_case_view_sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
