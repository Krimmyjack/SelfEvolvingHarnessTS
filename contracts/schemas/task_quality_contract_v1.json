{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "task-quality-contract/1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "contract_id",
    "task_type",
    "objective",
    "preserve",
    "harms",
    "evidence_expectations",
    "verification_dimensions",
    "abstention_conditions"
  ],
  "properties": {
    "schema_version": {"const": "task-quality-contract/1"},
    "contract_id": {"type": "string", "pattern": "^[a-z][a-z0-9._:-]*[a-z0-9]$"},
    "task_type": {"enum": ["forecast", "classification", "anomaly_detection"]},
    "objective": {"enum": ["forecast_future_values", "preserve_class_evidence", "preserve_anomaly_evidence"]},
    "preserve": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"enum": ["observed_values_outside_suspect_region", "temporal_order", "series_length", "forecast_relevant_structure", "class_relevant_structure", "anomaly_events"]}
    },
    "harms": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"enum": ["unnecessary_modification", "global_over_smoothing", "future_information_use", "out_of_scope_change", "event_erasure"]}
    },
    "evidence_expectations": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"enum": ["public_observation", "fixed_public_probe_panel", "candidate_execution_receipt"]}
    },
    "verification_dimensions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"enum": ["operator_legality", "execution_success", "finite_output", "shape_preservation", "effect_distinctness", "modification_scope"]}
    },
    "abstention_conditions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"enum": ["insufficient_public_evidence", "no_effect_distinct_candidate", "risk_guard_failure", "capability_unavailable"]}
    }
  }
}
