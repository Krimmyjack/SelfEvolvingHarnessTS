{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "harness-snapshot/1",
  "title": "HarnessSnapshot",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "instruction", "skills", "memories", "retrieval", "candidate_policy", "verification", "dependency_shas", "harness_content_sha", "runtime_bundle_sha"],
  "properties": {
    "schema_version": {"const": "harness-snapshot/1"},
    "instruction": {"type": "string", "minLength": 1},
    "skills": {"type": "array", "items": {"$ref": "skill_entry_v1.json"}},
    "memories": {"type": "array", "items": {"$ref": "memory_entry_v1.json"}},
    "retrieval": {"type": "object"},
    "candidate_policy": {"type": "object"},
    "verification": {"type": "object"},
    "dependency_shas": {"type": "object", "additionalProperties": {"type": "string", "pattern": "^[0-9a-f]{64}$"}},
    "harness_content_sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "runtime_bundle_sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
