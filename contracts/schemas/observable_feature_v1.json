{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "observable-feature/1",
  "title": "Observable applicability leaf",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["feature", "op", "value"],
      "properties": {
        "feature": {"enum": ["missing_fraction", "longest_missing_run_fraction", "local_robust_z_peak", "estimated_region_start_fraction", "estimated_region_end_fraction", "level_excursion_score", "estimated_level_offset", "period_change_score", "period_reliability"]},
        "op": {"enum": [">", ">=", "<", "<=", "=="]},
        "value": {"type": "number"}
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["feature", "op", "value"],
      "properties": {
        "feature": {"enum": ["missing_fraction", "longest_missing_run_fraction", "local_robust_z_peak", "estimated_region_start_fraction", "estimated_region_end_fraction", "level_excursion_score", "estimated_level_offset", "period_change_score", "period_reliability"]},
        "op": {"const": "=="},
        "value": {"enum": ["zero", "very_low", "low", "medium", "high"]}
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["feature", "op", "value"],
      "properties": {
        "feature": {"enum": ["missing_fraction", "longest_missing_run_fraction", "local_robust_z_peak", "estimated_region_start_fraction", "estimated_region_end_fraction", "level_excursion_score", "estimated_level_offset", "period_change_score", "period_reliability"]},
        "op": {"const": "in"},
        "value": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["zero", "very_low", "low", "medium", "high"]}}
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["feature", "op", "value"],
      "properties": {
        "feature": {"const": "period_repair_available"},
        "op": {"const": "=="},
        "value": {"type": "boolean"}
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["feature", "op", "value"],
      "properties": {
        "feature": {"const": "task_kind"},
        "op": {"const": "=="},
        "value": {"enum": ["forecast", "classification", "anomaly_detection"]}
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["feature", "op", "value"],
      "properties": {
        "feature": {"const": "period_evidence_status"},
        "op": {"const": "=="},
        "value": {"enum": ["OK", "UNKNOWN"]}
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["feature", "op", "value"],
      "properties": {
        "feature": {"enum": ["imputation_probe_direction", "clipping_probe_direction", "denoising_probe_direction", "level_probe_direction"]},
        "op": {"const": "=="},
        "value": {"enum": ["positive", "flat", "overdose_collapse", "negative", "unknown"]}
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["feature", "op", "value"],
      "properties": {
        "feature": {"const": "task_kind"},
        "op": {"const": "in"},
        "value": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["forecast", "classification", "anomaly_detection"]}}
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["feature", "op", "value"],
      "properties": {
        "feature": {"const": "period_evidence_status"},
        "op": {"const": "in"},
        "value": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["OK", "UNKNOWN"]}}
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["feature", "op", "value"],
      "properties": {
        "feature": {"enum": ["imputation_probe_direction", "clipping_probe_direction", "denoising_probe_direction", "level_probe_direction"]},
        "op": {"const": "in"},
        "value": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["positive", "flat", "overdose_collapse", "negative", "unknown"]}}
      }
    }
  ]
}
