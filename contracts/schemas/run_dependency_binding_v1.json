{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "run-dependency-binding/1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "task_context_sha", "evaluator_adapter_id", "instrument_epoch", "corpus_epoch", "capability_bundle_sha", "runtime_sha", "harness_sha", "code_commit", "provider_id", "model_id"],
  "properties": {
    "schema_version": {"const": "run-dependency-binding/1"},
    "task_context_sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "evaluator_adapter_id": {"type": "string", "minLength": 1},
    "instrument_epoch": {"type": "string", "minLength": 1},
    "corpus_epoch": {"type": "string", "minLength": 1},
    "capability_bundle_sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "runtime_sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "harness_sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "code_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "provider_id": {"type": "string", "minLength": 1},
    "model_id": {"type": "string", "minLength": 1}
  }
}
