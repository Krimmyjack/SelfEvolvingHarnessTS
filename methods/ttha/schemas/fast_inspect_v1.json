{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"fast-inspect/1",
  "type":"object",
  "additionalProperties":false,
  "required":["inspected_region_fractions","requested_public_tools","uncertainty"],
  "properties":{
    "inspected_region_fractions":{
      "type":"array",
      "items":{
        "type":"array","minItems":2,"maxItems":2,
        "items":{"type":"number","minimum":0.0,"maximum":1.0}
      }
    },
    "requested_public_tools":{"type":"array","items":{"type":"string"},"uniqueItems":true},
    "uncertainty":{"enum":["low","medium","high"]}
  }
}
