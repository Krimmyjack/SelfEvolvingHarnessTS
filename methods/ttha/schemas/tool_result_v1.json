{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"tool-result/1",
  "type":"object",
  "additionalProperties":false,
  "required":["schema_version","call_id","tool_name","ok","public_result","receipt_sha"],
  "properties":{
    "schema_version":{"const":"tool-result/1"},
    "call_id":{"type":"string"},
    "tool_name":{"type":"string"},
    "ok":{"type":"boolean"},
    "public_result":{"type":"object"},
    "receipt_sha":{"type":"string","pattern":"^[0-9a-f]{64}$"}
  }
}
