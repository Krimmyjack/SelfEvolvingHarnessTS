{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"slow-edit/1",
  "$defs":{
    "observable_leaf":{"$comment":"injected from contracts/schemas/observable_feature_v1.json"},
    "behavior_predicate":{"$comment":"injected from behavior_predicate_v1.json"},
    "learned_skill_entry":{"$comment":"injected from contracts/schemas/skill_entry_v1.json"},
    "memory_entry":{"$comment":"injected from contracts/schemas/memory_entry_v1.json"},
    "applicability":{
      "oneOf":[
        {"$ref":"#/$defs/observable_leaf"},
        {
          "type":"object","additionalProperties":false,"required":["const"],
          "properties":{"const":{"type":"boolean"}}
        },
        {
          "type":"object","additionalProperties":false,"required":["all"],
          "properties":{"all":{"type":"array","minItems":1,"items":{"$ref":"#/$defs/applicability"}}}
        },
        {
          "type":"object","additionalProperties":false,"required":["any"],
          "properties":{"any":{"type":"array","minItems":1,"items":{"$ref":"#/$defs/applicability"}}}
        },
        {
          "type":"object","additionalProperties":false,"required":["not"],
          "properties":{"not":{"$ref":"#/$defs/applicability"}}
        }
      ]
    },
    "canonical_id":{"type":"string","pattern":"^[a-z][a-z0-9]*(?:[-_][a-z0-9]+)*$"},
    "sha256":{"type":"string","pattern":"^[0-9a-f]{64}$"},
    "surface_id":{"type":"string","minLength":1},
    "dependency_preconditions":{
      "type":"object",
      "additionalProperties":{"$ref":"#/$defs/sha256"}
    },
    "behavior_predictions":{
      "type":"array","minItems":1,"uniqueItems":true,
      "items":{"$ref":"#/$defs/behavior_predicate"}
    },
    "nonempty_text_list":{
      "type":"array","minItems":1,"uniqueItems":true,
      "items":{"type":"string","minLength":1}
    },
    "risk_case_list":{
      "type":"array","uniqueItems":true,
      "items":{"type":"string","pattern":"^m0-[0-9]{4}$"}
    }
  },
  "type":"object",
  "additionalProperties":false,
  "required":["edit_manifest"],
  "properties":{
    "edit_manifest":{
      "oneOf":[
        {
          "type":"object",
          "additionalProperties":false,
          "required":[
            "edit_id","base_harness_sha","target_pattern_id","target_surface_id",
            "operation","surface_precondition","dependency_precondition_shas",
            "new_value","observable_applicability",
            "predicted_agent_behavior_change","predicted_data_effect","falsification_condition"
          ],
          "properties":{
            "edit_id":{"$ref":"#/$defs/canonical_id"},
            "base_harness_sha":{"$ref":"#/$defs/sha256"},
            "target_pattern_id":{"$ref":"#/$defs/canonical_id"},
            "target_surface_id":{"$ref":"#/$defs/surface_id"},
            "operation":{"const":"ADD"},
            "surface_precondition":{
              "type":"object","additionalProperties":false,"required":["kind"],
              "properties":{"kind":{"const":"ABSENT"}}
            },
            "dependency_precondition_shas":{"$ref":"#/$defs/dependency_preconditions"},
            "new_value":{
              "oneOf":[
                {"$ref":"#/$defs/learned_skill_entry"},
                {"$ref":"#/$defs/memory_entry"}
              ]
            },
            "observable_applicability":{"$ref":"#/$defs/applicability"},
            "predicted_agent_behavior_change":{"$ref":"#/$defs/behavior_predictions"},
            "predicted_data_effect":{"$ref":"#/$defs/nonempty_text_list"},
            "automatically_selected_risk_cases":{"$ref":"#/$defs/risk_case_list"},
            "falsification_condition":{"$ref":"#/$defs/nonempty_text_list"}
          }
        },
        {
          "type":"object",
          "additionalProperties":false,
          "required":[
            "edit_id","base_harness_sha","target_pattern_id","target_surface_id",
            "operation","surface_precondition","dependency_precondition_shas",
            "minimal_patch","predicted_agent_behavior_change","predicted_data_effect",
            "falsification_condition"
          ],
          "properties":{
            "edit_id":{"$ref":"#/$defs/canonical_id"},
            "base_harness_sha":{"$ref":"#/$defs/sha256"},
            "target_pattern_id":{"$ref":"#/$defs/canonical_id"},
            "target_surface_id":{"$ref":"#/$defs/surface_id"},
            "operation":{"const":"PATCH"},
            "surface_precondition":{
              "type":"object","additionalProperties":false,"required":["kind","sha"],
              "properties":{"kind":{"const":"SHA"},"sha":{"$ref":"#/$defs/sha256"}}
            },
            "dependency_precondition_shas":{"$ref":"#/$defs/dependency_preconditions"},
            "minimal_patch":{
              "type":"object","additionalProperties":false,"required":["value"],
              "properties":{"value":{}}
            },
            "observable_applicability":{
              "oneOf":[{"type":"null"},{"$ref":"#/$defs/applicability"}]
            },
            "predicted_agent_behavior_change":{"$ref":"#/$defs/behavior_predictions"},
            "predicted_data_effect":{"$ref":"#/$defs/nonempty_text_list"},
            "automatically_selected_risk_cases":{"$ref":"#/$defs/risk_case_list"},
            "falsification_condition":{"$ref":"#/$defs/nonempty_text_list"}
          }
        }
      ]
    }
  }
}
