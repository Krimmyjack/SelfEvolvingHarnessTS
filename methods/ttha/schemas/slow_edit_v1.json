        "surface_precondition":{"type":"object"},
        "dependency_precondition_shas":{"type":"object"},
        "minimal_patch":{"type":["object","null"]},
        "new_value":{"type":["object","null"]},
        "observable_applicability":{"type":["object","null"]},
        "predicted_agent_behavior_change":{"type":"array","items":{"type":"string"}},
        "predicted_data_effect":{"type":"array","items":{"type":"string"}},
        "automatically_selected_risk_cases":{"type":"array","items":{"type":"string"}},
