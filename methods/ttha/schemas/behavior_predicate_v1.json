{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"behavior-predicate/1",
  "title":"Closed M0 predicted-behavior predicate",
  "oneOf":[
    {
      "type":"string",
      "pattern":"^retrieve_skill:[a-z][a-z0-9]*(?:[-_][a-z0-9]+)*$"
    },
    {
      "$comment":"canonical forecast operator values are injected at load time",
      "type":"string",
      "enum":[]
    },
    {
      "type":"string",
      "enum":[
        "supply_effect_distinct",
        "choose_candidate_kind:identity",
        "choose_candidate_kind:program",
        "identity_retained",
        "effective_view_unchanged_out_of_scope"
      ]
    },
    {
      "type":"string",
      "pattern":"^scope_modified_fraction<=(?:0(?:\\.\\d+)?|1(?:\\.0+)?)$"
    },
    {
      "type":"string",
      "pattern":"^localization_iou>=(?:0(?:\\.\\d+)?|1(?:\\.0+)?)$"
    }
  ]
}
