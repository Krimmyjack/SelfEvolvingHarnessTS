{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"agent-envelope/1",
  "oneOf":[
    {
      "type":"object",
      "additionalProperties":false,
      "required":["schema_version","kind","stage","payload"],
      "properties":{
        "schema_version":{"const":"agent-envelope/1"},
        "kind":{"const":"stage_result"},
        "stage":{"type":"string","pattern":"^[a-z][a-z0-9_]*$"},
        "payload":{"type":"object"}
      }
    },
    {
      "type":"object",
      "additionalProperties":false,
      "required":["schema_version","kind","call_id","tool_name","arguments"],
      "properties":{
        "schema_version":{"const":"agent-envelope/1"},
        "kind":{"const":"tool_request"},
        "call_id":{"type":"string","pattern":"^[a-z][a-z0-9_-]*$"},
        "tool_name":{"type":"string","pattern":"^[a-z][a-z0-9_]*$"},
        "arguments":{"type":"object"}
      }
    },
    {
      "type":"object",
      "additionalProperties":false,
      "required":["schema_version","kind","stage","reason_code"],
      "properties":{
        "schema_version":{"const":"agent-envelope/1"},
        "kind":{"const":"no_proposal"},
        "stage":{"const":"edit"},
        "reason_code":{"enum":["insufficient_public_evidence","no_authorized_minimal_edit","risk_too_high"]}
      }
    }
  ]
}
